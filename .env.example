# Chaves das corretoras para sincronizar o Diário (use chaves READ-ONLY).
# Copie para .env e preencha. O .env nunca vai para o git.

# BingX
BINGX_API_KEY=
BINGX_API_SECRET=

# OKX (precisa também da passphrase definida ao criar a chave)
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSWORD=

# Hyperliquid (endereço da carteira; private key opcional p/ leitura)
HYPERLIQUID_WALLET=
HYPERLIQUID_PRIVATE_KEY=

# SimpleFX — integração via API própria virá em etapa futura
# SIMPLEFX_CLIENT_ID=
# SIMPLEFX_CLIENT_SECRET=

# Bybit DEMO trading (módulo de Automação — ordens em conta demo, gratuita).
# Crie a chave em bybit.com > Demo Trading > API. NÃO são as chaves da conta
# real: a demo tem chaves próprias e saldo virtual.
BYBIT_DEMO_API_KEY=
BYBIT_DEMO_API_SECRET=
