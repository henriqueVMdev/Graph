# Chaves das corretoras para sincronizar o Diário (use chaves READ-ONLY).
# Copie para .env e preencha. O .env nunca vai para o git.

# BingX
BINGX_API_KEY=
BINGX_API_SECRET=

# OKX (precisa também da passphrase definida ao criar a chave)
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSWORD=

# Hyperliquid (endereço da carteira; private key opcional p/ leitura)
HYPERLIQUID_WALLET=
HYPERLIQUID_PRIVATE_KEY=

# SimpleFX — integração via API própria virá em etapa futura
# SIMPLEFX_CLIENT_ID=
# SIMPLEFX_CLIENT_SECRET=

# Bybit DEMO trading (módulo de Automação — ordens em conta demo, gratuita).
# Crie a chave em bybit.com > Demo Trading > API. NÃO são as chaves da conta
# real: a demo tem chaves próprias e saldo virtual.
BYBIT_DEMO_API_KEY=
BYBIT_DEMO_API_SECRET=

# Bybit REAL (Automação, mode=real). CUIDADO: DINHEIRO REAL na mainnet.
# Crie as chaves com permissão apenas de Trade (sem saque/withdraw).
# Conta pessoal:
BYBIT_REAL_API_KEY=
BYBIT_REAL_API_SECRET=
# Conta prop firm:
BYBIT_PROP_API_KEY=
BYBIT_PROP_API_SECRET=

# EIA (estoques/producao/demanda de energia — gratis): https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# Métricas on-chain BTC avançadas. Glassnode fornece NUPL e realized price STH/LTH.
GLASSNODE_API_KEY=
# CryptoQuant: informe a URL completa permitida pelo seu plano para cada série.
CRYPTOQUANT_API_KEY=
CRYPTOQUANT_EXCHANGE_WHALE_RATIO_URL=
CRYPTOQUANT_ESTIMATED_LEVERAGE_RATIO_URL=
CRYPTOQUANT_RETAIL_DEMAND_30D_URL=
CRYPTOQUANT_WHALE_REALIZED_PRICE_URL=
CRYPTOQUANT_WHALE_LAST_ACTIVE_URL=

# SEC exige User-Agent identificável para acesso automatizado ao EDGAR.
SEC_API_USER_AGENT="GraphQuantLab seu-email@dominio.com"

# Carteiras BTC adicionais (rótulos próprios, pois atribuições mudam com o tempo).
# BTC_FAMOUS_WALLETS_JSON='[{"label":"Tesouraria","entity":"Empresa X","address":"bc1...","confidence":"verified"}]'

# Eventos macro próprios: array JSON com date, title, category, impact e time.
# MACRO_EVENTS_JSON='[{"date":"2026-07-29","time":"18:00 UTC","title":"FOMC","category":"macro","impact":"high"}]'
